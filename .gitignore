# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# package-lock.json volontairement non versionné (voir README) : régénérez-le
# avec `npm install`.
/package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Données personnelles des adhérents (RGPD) : ne jamais committer les
# fichiers réels, seuls les .sample.json (données factices) sont versionnés.
/src/data/members.json
/src/data/accounts.json
/src/data/*.csv
