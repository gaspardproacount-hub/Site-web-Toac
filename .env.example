# ────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env.local (dev) ou renseignez ces variables dans
# les "Environment Variables" de votre projet Vercel (prod). Ne committez
# JAMAIS de vraies valeurs dans un fichier .env versionné.
# ────────────────────────────────────────────────────────────────────────

# Clé secrète utilisée pour signer les cookies de session de l'espace
# adhérents. Générez une valeur aléatoire longue, par ex. :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Monetico Paiement (Crédit Mutuel / CIC) ───────────────────────────
# Récupérables dans l'espace commerçant Monetico du club.
MONETICO_TPE=
MONETICO_CODE_SOCIETE=
MONETICO_CLE_HMAC=
# URL de base du site (sans slash final), utilisée pour les redirections
# de fin de paiement, ex. https://toac-triathlon.vercel.app
MONETICO_URL_RETOUR=
# Passez à "true" pour utiliser la plateforme de test Monetico avant la
# mise en production (TPE de test fourni par Monetico).
MONETICO_TEST_MODE=true

# ─── Envoi d'emails (formulaire de contact) ────────────────────────────
# Optionnel : sans clé Resend, les messages du formulaire de contact sont
# simplement journalisés côté serveur (mode démo).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Base de données (commandes Monetico + demandes d'adhésion) ───────
# Chaîne de connexion Postgres. N'importe quel Postgres gratuit convient :
# Vercel Postgres/Neon (recommandé, intégration en un clic depuis Vercel),
# Supabase, Railway… Sans cette variable, les commandes Monetico et les
# demandes d'adhésion en ligne ne sont pas enregistrées (voir README § 5bis).
DATABASE_URL=

# ─── Stockage des justificatifs (tarif réduit) ─────────────────────────
# Jeton fourni par Vercel Blob (projet Vercel → Storage → Create Database →
# Blob, offre gratuite). Sans cette variable, les justificatifs uploadés
# dans le formulaire d'adhésion ne sont pas conservés (le reste du
# formulaire continue de fonctionner).
BLOB_READ_WRITE_TOKEN=
